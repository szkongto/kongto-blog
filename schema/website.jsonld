{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "深圳市江图科技有限公司",
  "url": "https://www.kongto.com",
  "description": "专注工业视频显示方案的技术型公司，为CNC数控系统、工业自动化设备提供显示器升级改造解决方案，主营FANUC数控显示器LCD升级、工业视频信号转换、工控专用显示器等产品",
  "publisher": {
    "@type": "Organization",
    "name": "深圳市江图科技有限公司"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://www.kongto.com/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}